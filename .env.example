# Copy this file to .env.local and fill in your keys.
# .env.local is git-ignored — never commit real secrets.
#
# Only ONE key is required for full functionality:
#
#   ANTHROPIC_API_KEY — Claude API key for /api/analyze and
#                       /api/briefing. Without this both routes
#                       fall back to deterministic mock output
#                       derived from the live market snapshot.
#                       Get one at https://console.anthropic.com
#
# All other data sources are free and key-less:
#   - /api/price       gold-api.com (free, no key)
#   - /api/signals     yahoo-finance2 npm (free, no key)
#   - /api/technicals  yahoo-finance2 npm (free, no key)
#   - /api/calendar    ForexFactory weekly JSON (free, no key)
#   - /api/news        Google News RSS (free, no key)

ANTHROPIC_API_KEY=
